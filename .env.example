# ========================
# Flask Configuration
# ========================
SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=True

# ========================
# Database (MySQL)
# ========================
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/job_assistant

# ========================
# JWT
# ========================
JWT_SECRET_KEY=change-this-jwt-secret-too

# ========================
# Ollama (IA Local)
# ========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_DEFAULT_MODEL=llama3

# ========================
# Upload de Arquivos
# ========================
# Deixe em branco para usar o padrão (static/uploads)
UPLOAD_FOLDER=
